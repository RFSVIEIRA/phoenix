<!-- PHOENIX by RFSVIEIRA -->
<layout width="1920" height="1080" font="fonts/verdana.ttf" fontColor="FFFFFF" loadFontSize="60">

	<image src="force/background.png" width="1920" height ="1080" layer="0"/>

	<menu menuIndex="0" mode="system" type="custom" imageType="fanart" >
		<itemDefaults alpha="0" x="center" y="center"  xOrigin="center" yOrigin="center" width="1920" height="1080" containerX="0" containerY="0" containerWidth="1920" containerHeight="1080" layer="4"/>
		<item selected="true" alpha=".4">
			<onEnter>
					<set duration=".5"><animate type="width" from="2220" to="1920"/></set>
					<set duration=".6"><animate type="alpha" to=".05"/> </set>
			</onEnter>
		</item>
	</menu>

	<image src="images/reflection.png" alpha="1" y="716" width="1920" height="366" layer="4"/>

	<image src="force/background.png" x="0" y="0" alpha="0" width="1920" height="1080" containerX="0" containerY="0" containerWidth="0" containerHeight="1080" layer="7">
		<onEnter >
			<set duration=".6"><animate type="alpha" to="1"/><animate type="containerWidth" to="1420"/></set>
		</onEnter>
	</image>


<!-- Artwork front -->
	<menu menuIndex="0" mode="system" type="custom" imageType="artwork_front" scaleMode="fit">
		<itemDefaults x="1450" y="-100" xOrigin="right" yOrigin="center" alpha="0" width="132" spacing="10" layer="11"/>
		<item selected="true" alpha="1" >
			<onEnter>
			<!-- Grow with ark-->
				<set duration=".8">
					<animate type="alpha" to="1" algorithm="easeOutQuad"/>
					<animate type="x"  to="285" algorithm="easeInOutSine"/>
					<animate type="y"  to="center" algorithm="easeOutCubic"/>
					<animate type="width" from="5" to="520" algorithm="easeOutBack"/>
					<animate type="xOrigin" to="center" algorithm="easeOutQuad"/>
				</set>
				<set duration=".2">
					<animate type="width" from="520" to="480" algorithm="easeOutBack"/>
				</set>
			</onEnter>
		</item>
	</menu>

<!-- Background of Artwork front -->
	<menu menuIndex="0" mode="commonlayout" type="custom" imageType="cristal" scaleMode="stretch">
		<itemDefaults x="1450" y="-100"  xOrigin="right" yOrigin="center" alpha="0" width="132"  spacing="10" layer="12"/>
		<item selected="true" alpha="1" >
			<onEnter>
				<set duration=".8">
					<animate type="alpha" to="1" algorithm="easeOutQuad"/>
					<animate type="x"  to="285" algorithm="easeInOutSine"/>
					<animate type="y"  to="center" algorithm="easeOutCubic"/>
					<animate type="width" from="9" to="526" algorithm="easeOutBack"/><animate type="height" from="44" to="716"/>
					<animate type="xOrigin" to="center"/></set>
				<set duration=".2"><animate type="width" from="526" to="490"/><animate type="height" from="716" to="660"/></set>
			</onEnter>
		</item>
	</menu>
	
<!--Top Line-->
